# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files
!override.tf
!override.tf.json
!*_override.tf
!*_override.tf.json

# Include .terraform.lock.hcl
!.terraform.lock.hcl

# Exclude sensitive variables (uncomment if you have secrets in .tfvars)
# *.tfvars
# *.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc
